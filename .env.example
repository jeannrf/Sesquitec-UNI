# Configuración de Conexión a Supabase (Frontend)
# Reemplaza con las credenciales de tu panel de Supabase (Settings -> API)
VITE_SUPABASE_URL=https://tu-proyecto.supabase.co
VITE_SUPABASE_ANON_KEY=tu-anon-key-de-supabase

# Conexión directa a base de datos (PostgreSQL) - Opcional para backend o herramientas
# URL de conexión: postgresql://postgres:[PASSWORD]@db.[PROJECT-ID].supabase.co:5432/postgres
DATABASE_URL=postgresql://postgres:[PASSWORD]@db.[PROJECT-ID].supabase.co:5432/postgres

# Pasarela de Pagos (Mercado Pago)
# Obtén tus credenciales desde developers.mercadopago.com
MP_ACCESS_TOKEN=tu-access-token-privado-de-pruebas-o-produccion
VITE_MP_PUBLIC_KEY=tu-public-key-de-pruebas-o-produccion
